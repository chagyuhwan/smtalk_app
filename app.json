{
  "expo": {
    "name": "smtalk",
    "slug": "smtalk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon2.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1f2937",
      "image": "./assets/appicon2.png",
      "resizeMode": "contain"
    },
    "autolinking": {
      "exclude": [
        "expo-firebase-core"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/appicon2.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "enableProguardInReleaseBuilds": false,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "게시글에 사진을 추가하기 위해 갤러리 접근 권한이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "게시글에 사진을 추가하기 위해 갤러리 접근 권한이 필요합니다.",
        "NSCameraUsageDescription": "게시글에 사진을 추가하기 위해 카메라 접근 권한이 필요합니다.",
        "NSUserNotificationsUsageDescription": "새로운 메시지를 받기 위해 알림 권한이 필요합니다.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.kanc.randomchat",
      "googleServicesFile": "./GoogleService-Info.plist",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon2.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "package": "com.kanc.randomchat",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c84661b3-d0f1-4bf1-a591-2b27eb4c6f5c"
      }
    }
  }
}
