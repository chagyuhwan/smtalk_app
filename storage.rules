rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 공통: 이미지 파일 + 용량 제한 검증 함수
    function isImageUnder(maxBytes) {
      return request.resource.size < maxBytes
        && request.resource.contentType.matches('image/.*');
    }

    // ==================== 아바타 (avatars) ====================
    match /avatars/{userId}/{fileName} {
      // 본인만 업로드/삭제, 5MB 이하 이미지
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isImageUnder(5 * 1024 * 1024);
      // 모든 인증된 사용자는 아바타를 읽을 수 있음
      allow read: if request.auth != null;
    }

    // ==================== 게시글 이미지 (posts) ====================
    match /posts/{postId}/{fileName} {
      // 인증된 사용자는 게시글 이미지를 업로드할 수 있음, 10MB 이하 이미지
      allow write: if request.auth != null
        && isImageUnder(10 * 1024 * 1024);
      // 모든 인증된 사용자는 게시글 이미지를 읽을 수 있음
      allow read: if request.auth != null;
    }

    // ==================== 메시지 이미지 (messages) ====================
    match /messages/{chatRoomId}/{fileName} {
      // 인증된 사용자는 업로드 가능, 10MB 이하 이미지
      // (읽기/쓰기 접근 제어는 클라이언트의 채팅방 참가자 검증과 병행)
      allow write: if request.auth != null
        && isImageUnder(10 * 1024 * 1024);
      // 읽기는 인증된 사용자만 가능
      allow read: if request.auth != null;
    }
  }
}
