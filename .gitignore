# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
# Release 키스토어는 절대 Git에 커밋하지 마세요!
android/app/release.keystore
android/keystore.properties

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# NICE config (민감한 정보 포함)
# config/nice.ts는 Git에 포함되지만, 실제 Secret은 환경 변수로 관리 권장

# Backend
backend/node_modules/
backend/.env
backend/*.log

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Firebase config files (민감한 정보 포함 가능)
# 주의: EAS Build를 위해 Git에 추가해야 할 수 있습니다
# GoogleService-Info.plist
# google-services.json

# IDE
.idea/

# Local properties
android/local.properties
ios/Pods/
ios/*.xcworkspace
ios/Podfile.lock

# Build files
android/app/build/
android/build/
ios/build/
