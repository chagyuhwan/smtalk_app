rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== 사용자 (users) ====================
    match /users/{userId} {
      // 인증된 사용자는 자신의 정보를 읽고 쓸 수 있음
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 다른 사용자의 문서 업데이트 허용 (좋아요 기능)
      // 중요한 필드들이 변경되지 않았는지 확인
      allow update: if request.auth != null && 
        request.auth.uid != userId &&
        // 필수 필드들이 변경되지 않았는지 확인
        request.resource.data.id == resource.data.id &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.phoneNumber == resource.data.phoneNumber &&
        // 보안상 중요한 필드들이 변경되지 않았는지 확인
        // 변경된 필드가 likeCount, likedBy, updatedAt만 포함하는지 확인
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'likedBy', 'updatedAt']);
      
      // 관리자는 모든 사용자 정보를 읽고 쓸 수 있음
      allow read, write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== 게시글 (posts) ====================
    match /posts/{postId} {
      // 인증된 사용자는 모든 게시글을 읽을 수 있음
      allow read: if request.auth != null;
      
      // 인증된 사용자는 게시글을 작성할 수 있음
      // 정지 상태 확인은 클라이언트에서 처리 (서버 규칙은 기본 검증만 수행)
      allow create: if request.auth != null && 
        request.resource.data.authorId == request.auth.uid;
      
      // 작성자만 자신의 게시글을 수정/삭제할 수 있음
      allow update, delete: if request.auth != null && 
        resource.data.authorId == request.auth.uid;
      
      // 관리자는 모든 게시글을 삭제할 수 있음
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== 채팅방 (chatRooms) ====================
    match /chatRooms/{roomId} {
      // 참가자만 채팅방을 읽을 수 있음
      allow read: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      
      // 참가자만 채팅방을 생성/수정할 수 있음
      allow create: if request.auth != null && 
        request.auth.uid in request.resource.data.participants;
      
      allow update: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      
      // 참가자만 채팅방을 삭제할 수 있음
      allow delete: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      
      // ==================== 메시지 (chatRooms/{roomId}/messages) ====================
      match /messages/{messageId} {
        // 채팅방 참가자만 메시지를 읽을 수 있음
        // 쿼리 컨텍스트에서도 작동하도록 채팅방 참가자 확인
        // get()은 쿼리 컨텍스트에서도 작동하며, 채팅방 문서가 존재하고 접근 가능해야 함
        // 채팅방 문서가 존재하고 사용자가 참가자인지 확인
        allow read: if request.auth != null && 
          exists(/databases/$(database)/documents/chatRooms/$(roomId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        
        // 메시지 작성: 채팅방 참가자만 작성 가능
        // 단, 일반 사용자가 운영자 계정에게 메시지를 보내는 것은 차단 (운영자가 사용자에게 보내는 것은 허용)
        // 정지 상태 확인은 클라이언트에서 처리 (서버 규칙은 기본 검증만 수행)
        allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/chatRooms/$(roomId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.receiverId != null &&
          request.resource.data.receiverId != request.auth.uid &&
          request.resource.data.text != null &&
          (
            // 발신자가 운영자인 경우 항상 허용
            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
            // 발신자가 운영자가 아닌 경우, 수신자가 운영자가 아니어야 함
            (!exists(/databases/$(database)/documents/users/$(request.resource.data.receiverId)) ||
             (exists(/databases/$(database)/documents/users/$(request.resource.data.receiverId)) &&
              get(/databases/$(database)/documents/users/$(request.resource.data.receiverId)).data.isAdmin != true))
          );
        
        // 발신자 또는 수신자만 자신의 메시지를 수정할 수 있음 (읽음 상태 업데이트 등)
        allow update: if request.auth != null && 
          exists(/databases/$(database)/documents/chatRooms/$(roomId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants &&
          (resource.data.senderId == request.auth.uid || 
           resource.data.receiverId == request.auth.uid);
        
        // 발신자만 자신의 메시지를 삭제할 수 있음
        allow delete: if request.auth != null && 
          exists(/databases/$(database)/documents/chatRooms/$(roomId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants &&
          resource.data.senderId == request.auth.uid;
      }
    }
    
    // ==================== 신고 (reports) ====================
    match /reports/{reportId} {
      // 인증된 사용자는 신고를 작성할 수 있음
      allow create: if request.auth != null && 
        request.resource.data.reportedBy == request.auth.uid;
      
      // 관리자만 신고를 읽을 수 있음
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // 관리자만 신고 상태를 업데이트할 수 있음
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== 구매 이력 (purchases) ====================
    match /purchases/{purchaseId} {
      // 인증된 사용자는 구매 이력을 작성할 수 있음
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // 자신의 구매 이력만 읽을 수 있음
      allow read: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // 관리자는 모든 구매 이력을 읽을 수 있음
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== 문의 (inquiries) ====================
    match /inquiries/{inquiryId} {
      // 인증된 사용자는 문의를 작성할 수 있음
      allow create: if request.auth != null && 
        request.resource.data.userId == request.auth.uid;
      
      // 자신의 문의만 읽을 수 있음
      allow read: if request.auth != null && 
        resource.data.userId == request.auth.uid;
      
      // 관리자는 모든 문의를 읽을 수 있음
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // 관리자만 문의 상태를 업데이트할 수 있음 (답변 등)
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // 관리자만 문의를 삭제할 수 있음
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // ==================== 에러 로그 (errorLogs) ====================
    match /errorLogs/{errorId} {
      // 모든 인증된 사용자는 에러 로그를 작성할 수 있음 (크래시 리포팅)
      // 인증되지 않은 경우도 허용 (웹 환경 대응)
      allow create: if true;
      
      // 관리자만 에러 로그를 읽을 수 있음
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      
      // 에러 로그는 수정/삭제 불가 (읽기 전용)
      allow update, delete: if false;
    }
  }
}

